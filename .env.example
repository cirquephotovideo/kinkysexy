# ═══════════════════════════════════════════════════════════════
# KinkySexy — Variables d'environnement
# Stack Next.js 14 + Prisma + NextAuth + Redis + MinIO + MeiliSearch
# ═══════════════════════════════════════════════════════════════

# ─── URLs publiques ──────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://kinky.pixeeplay.com
NEXTAUTH_URL=https://kinky.pixeeplay.com

# ─── Database ────────────────────────────────────────────────────
POSTGRES_USER=kinky
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=kinkysexy
DATABASE_URL=postgres://kinky:change-me-postgres@postgres:5432/kinkysexy

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── NextAuth (générer : openssl rand -base64 64) ────────────────
NEXTAUTH_SECRET=change-me-nextauth-secret-min-32-chars-loooong

# ─── Admin par défaut (créé au seed) ─────────────────────────────
ADMIN_EMAIL=arnaud@gredai.com
ADMIN_PASSWORD=KinkySexy2026!

# ─── MinIO (S3) ──────────────────────────────────────────────────
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_URL=https://kinky.pixeeplay.com/storage
S3_BUCKET=kinkysexy
S3_ACCESS_KEY=kinkyminio
S3_SECRET_KEY=change-me-s3-secret

# ─── MeiliSearch ─────────────────────────────────────────────────
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_API_KEY=change-me-meili-key

# ─── Mail (Resend prod / Mailpit dev) ────────────────────────────
RESEND_API_KEY=re_REPLACE
EMAIL_FROM=hello@kinky.pixeeplay.com
SMTP_HOST=mailpit
SMTP_PORT=1025

# ─── Stripe (mode test → live au go-live) ────────────────────────
STRIPE_API_KEY=sk_test_REPLACE
STRIPE_WEBHOOK_SECRET=whsec_REPLACE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE

# ─── PayPal ──────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=REPLACE
PAYPAL_CLIENT_SECRET=REPLACE
PAYPAL_MODE=sandbox

# ─── Dropshipping ────────────────────────────────────────────────
BIGBUY_API_KEY=REPLACE
BIGBUY_API_URL=https://api.bigbuy.eu
EPROLO_API_KEY=REPLACE
CJ_API_KEY=REPLACE
CJ_EMAIL=arnaud@gredai.com

# ─── IA ──────────────────────────────────────────────────────────
GEMINI_API_KEY=REPLACE
OPENAI_API_KEY=REPLACE
ANTHROPIC_API_KEY=REPLACE

# ─── Telegram bot ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=REPLACE
TELEGRAM_CHAT_ID=REPLACE

# ─── Mode ────────────────────────────────────────────────────────
NODE_ENV=production

# ─── Cross-sell Sun ──────────────────────────────────────────────
KINKY_API_ALLOWED_ORIGINS=https://sun.pixeeplay.com,https://kinky.pixeeplay.com
